{
  "name": "coach-mobile",
  "version": "1.0.1",
  "main": "index.js",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "doctor": "npx expo-doctor",
    "build:android:internal": "node ../scripts/mobile-build-guard.mjs coach internal android",
    "build:android:store-test": "node ../scripts/mobile-build-guard.mjs coach store-test android",
    "build:android:store-live": "node ../scripts/mobile-build-guard.mjs coach store-live android",
    "build:ios:store-test": "node ../scripts/mobile-build-guard.mjs coach store-test ios",
    "build:ios:store-live": "node ../scripts/mobile-build-guard.mjs coach store-live ios",
    "export:web": "expo export --platform web --output-dir dist-web-check",
    "submit:android:store-test": "node ../scripts/mobile-submit-guard.mjs coach android",
    "submit:android:store-live": "node ../scripts/mobile-submit-guard.mjs coach android store-live",
    "submit:ios:store-test": "node ../scripts/mobile-submit-guard.mjs coach ios",
    "submit:ios:store-live": "node ../scripts/mobile-submit-guard.mjs coach ios store-live"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "2.102.1",
    "expo": "~54.0.35",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.12",
    "expo-local-authentication": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0"
  }
}
