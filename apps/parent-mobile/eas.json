{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "environment": "development",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_SUPABASE_ENV": "test",
        "EXPO_PUBLIC_ALLOW_LIVE_SUPABASE": "false"
      }
    },
    "internal": {
      "environment": "preview",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_SUPABASE_ENV": "test",
        "EXPO_PUBLIC_ALLOW_LIVE_SUPABASE": "false"
      }
    },
    "store-test": {
      "environment": "production",
      "distribution": "store",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_SUPABASE_ENV": "test",
        "EXPO_PUBLIC_ALLOW_LIVE_SUPABASE": "false"
      }
    },
    "store-live": {
      "environment": "production",
      "distribution": "store",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_SUPABASE_ENV": "live",
        "EXPO_PUBLIC_ALLOW_LIVE_SUPABASE": "true"
      }
    }
  },
  "submit": {
    "store-test": {
      "android": {
        "track": "alpha",
        "releaseStatus": "draft",
        "changesNotSentForReview": true,
        "serviceAccountKeyPath": "../mobile-release-evidence/credentials/football-player-mobile-expo-play-submit-service-account.json"
      },
      "ios": {
        "ascAppId": "6772061464"
      }
    },
    "store-live": {
      "android": {
        "track": "alpha",
        "releaseStatus": "draft",
        "changesNotSentForReview": true,
        "serviceAccountKeyPath": "../mobile-release-evidence/credentials/football-player-mobile-expo-play-submit-service-account.json"
      },
      "ios": {
        "ascAppId": "6772061464"
      }
    }
  }
}
